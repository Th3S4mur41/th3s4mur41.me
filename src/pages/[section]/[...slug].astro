---
import { getImage } from "astro:assets";
import { getCollection, render } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";
import BlogPostingSchema from "../../components/BlogPostingSchema.astro";
import Image from "../../components/Image.astro";
import PodcastEpisodeSchema from "../../components/PodcastEpisodeSchema.astro";
import Reactions from "../../components/Reactions.astro";
import RelatedArticles from "../../components/RelatedArticles.astro";
import Layout from "../../layouts/Layout.astro";
import { formatSiteDate } from "../../utils/config.js";
import { getEntryIds, getSeriesSlug, isSeriesContainerId, normalizeEntryId } from "../../utils/contentSeries";
import { isPreviewFutureContentEnabled, isVisibleContent } from "../../utils/contentVisibility";
import type { ProcessedWebmentions } from "../../utils/webmentions";
import { fetchWebmentions, processWebmentions } from "../../utils/webmentions";

/**
 * Unified dynamic route for both blog posts and speaking entries.
 * Supports draft preview slugs prefixed with `_draft-` the same way the original
 * individual route files did. Eliminates duplicated logic (images, title truncation, meta setup).
 */
export async function getStaticPaths() {
	const now = new Date();
	const previewFuture = isPreviewFutureContentEnabled();

	const [blogEntries, speakingEntries] = await Promise.all([getCollection("blog"), getCollection("speaking")]);

	const allBlogIds = getEntryIds(blogEntries);
	const visibleBlogEntries = blogEntries.filter((entry: any) => isVisibleContent(entry.data, { now, previewFuture }));
	const visibleSpeakingEntries = speakingEntries.filter((entry: any) => isVisibleContent(entry.data, { now, previewFuture }));
	const visibleBlogByNormalizedId = new Map(
		visibleBlogEntries.map((entry: any) => [normalizeEntryId(entry.id), entry] as const),
	);

	const blogPaths = visibleBlogEntries
		.filter((entry: any) => !isSeriesContainerId(entry.id, allBlogIds))
		.map((entry: any) => {
			const seriesSlug = getSeriesSlug(entry.id);
			const seriesEntry = (seriesSlug ? visibleBlogByNormalizedId.get(seriesSlug) : null) as any;

			return {
				params: { section: "blog", slug: normalizeEntryId(entry.id) },
				props: {
					article: entry,
					section: "blog",
					series:
						seriesSlug && seriesEntry
							? {
									slug: seriesSlug,
									title: seriesEntry.data.title,
								}
							: null,
				},
			};
		});

	const speakingPaths = visibleSpeakingEntries.map((entry: any) => ({
		params: { section: "speaking", slug: normalizeEntryId(entry.id) },
		props: { article: entry, section: "speaking" },
	}));

	const seriesSlugs = new Set<string>();
	for (const entry of visibleBlogEntries) {
		const seriesSlug = getSeriesSlug(entry.id);
		if (seriesSlug) seriesSlugs.add(seriesSlug);
	}

	const seriesPaths = [...seriesSlugs].map((seriesSlug) => ({
		params: { section: "blog", slug: seriesSlug },
		props: { section: "blog" },
	}));

	const paths = [...blogPaths, ...speakingPaths, ...seriesPaths];

	return paths;
}

// Runtime params.
const { section, slug } = Astro.params as {
	section?: string;
	slug?: string;
};

const SUPPORTED_SECTIONS = ["blog", "speaking"] as const;
type Section = (typeof SUPPORTED_SECTIONS)[number];

if (!section || !SUPPORTED_SECTIONS.includes(section as Section)) {
	throw new Error(`Invalid section: ${section}`);
}

// Backward compat: normalize legacy draft slug back to original entry id.
const normalizedSlug = slug?.startsWith("_draft-") ? slug.slice("_draft-".length) : slug;
if (!normalizedSlug) {
	throw new Error("Missing slug param");
}

const previewFuture = isPreviewFutureContentEnabled();
const now = new Date();

const { article: staticPathArticle, series: staticPathSeries } = Astro.props as {
	article?: any;
	series?: { slug: string; title: string } | null;
};
const article = staticPathArticle ?? null;
const series = staticPathSeries ?? null;

let seriesArticles: any[] = [];
let seriesIntroEntry: any | null = null;

if (!article && section === "blog") {
	const allBlogEntries = await getCollection("blog");
	const allBlogIds = getEntryIds(allBlogEntries);
	const visibleBlogEntries = allBlogEntries.filter((entry: any) =>
		isVisibleContent(entry.data, { now, previewFuture }),
	);
	const hasSeriesChildren = visibleBlogEntries.some((entry: any) => {
		const id = normalizeEntryId(entry.id);
		return id !== normalizedSlug && id.startsWith(`${normalizedSlug}/`);
	});

	if (hasSeriesChildren) {
		seriesIntroEntry = visibleBlogEntries.find((entry: any) => normalizeEntryId(entry.id) === normalizedSlug) ?? null;
		seriesArticles = visibleBlogEntries
			.filter((entry: any) => {
				const id = normalizeEntryId(entry.id);
				if (id === normalizedSlug) return false;
				if (!id.startsWith(`${normalizedSlug}/`)) return false;
				return !isSeriesContainerId(entry.id, allBlogIds);
			})
			.sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());
	}
}

const isSeriesPage = section === "blog" && seriesArticles.length > 0;
if (!article && !isSeriesPage) {
	throw new Error(`Article not found: ${section}/${normalizedSlug}`);
}

// Safety: even if someone hits a legacy `_draft-` URL directly, never render unpublished items.
// Future-dated items are only visible when PREVIEW_FUTURE_CONTENT is enabled at build/runtime.
if (!isSeriesPage && article) {
	const isVisible = isVisibleContent(article.data, { previewFuture });
	if (!isVisible) {
		throw new Error(`Content not visible: ${section}/${normalizedSlug}`);
	}
}

// Render MD/MDX content for the current page kind.
const ArticleContent = !isSeriesPage && article ? (await render(article)).Content : null;
const SeriesIntroContent = isSeriesPage && seriesIntroEntry ? (await render(seriesIntroEntry)).Content : null;

// With `image()` in collection schema, content image frontmatter is resolved to ImageMetadata.
const pageEntry = isSeriesPage ? seriesIntroEntry : article;
const resolvedImage = pageEntry?.data.image;

const img =
	resolvedImage
		? await getImage({
				src: resolvedImage,
				width: 1200,
				height: 630,
				format: "jpg",
			})
		: undefined;

// Title truncation logic (shared previously) - ensure max 60 chars accounting for site suffix.
const SITE_SUFFIX = "| Th3S4mur41.me";
const MAX_TITLE_LEN = 60 - SITE_SUFFIX.length;
function truncateTitle(original: string): string {
	if (!original) return original;
	if (original.length <= MAX_TITLE_LEN) return original;
	const window = original.slice(0, MAX_TITLE_LEN);
	const findLast = (chars: string) => {
		let pos = -1;
		for (const ch of chars) {
			const i = window.lastIndexOf(ch);
			if (i > pos) pos = i;
		}
		return pos;
	};
	let pos = findLast(".?!");
	if (pos !== -1) {
		return window.slice(0, pos + 1).trim();
	}
	const findLastFollowedByWhitespace = (chars: string) => {
		for (let i = window.length - 1; i >= 0; i--) {
			const ch = window[i];
			if (!chars.includes(ch)) continue;
			const nextChar = original[i + 1];
			if (nextChar && /\s/.test(nextChar)) return i;
		}
		return -1;
	};
	pos = findLastFollowedByWhitespace(":;");
	if (pos !== -1) {
		return window.slice(0, pos).trim();
	}
	pos = window.lastIndexOf(",");
	if (pos !== -1) {
		const cut = Math.min(pos + 1, MAX_TITLE_LEN - 3);
		return `${window.slice(0, cut).trimEnd()}...`;
	}
	const spacePos = window.lastIndexOf(" ", MAX_TITLE_LEN - 3);
	if (spacePos > 20) {
		return `${window.slice(0, spacePos).trimEnd()}...`;
	}
	return `${window.slice(0, MAX_TITLE_LEN - 3).trimEnd()}...`;
}

function humanizeSlug(value: string): string {
	return value
		.split("/")
		.filter(Boolean)
		.pop()
		?.split("-")
		.map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
		.join(" ") ?? value;
}

const pageTitle = pageEntry?.data.title ?? humanizeSlug(normalizedSlug);
const truncatedTitle = truncateTitle(pageTitle);
const translations = pageEntry?.data.translations?.map((t: any) => ({ language: t.language, url: t.url })) ?? undefined;
const articleEyebrowText = !isSeriesPage && section === "blog" && series ? series.title : article?.data.eyebrow;
const articleEyebrowHref = !isSeriesPage && section === "blog" && series ? `/blog/${series.slug}/` : null;

// Fetch webmentions if reactions are enabled for this article
let webmentions: ProcessedWebmentions | null = null;
if (!isSeriesPage && article?.data.reactions) {
	const apiKey = import.meta.env.WEBMENTIONIO_API_KEY;
	const pageUrl = Astro.url.href;

	const mentions = await fetchWebmentions(pageUrl, apiKey);
	if (mentions) {
		webmentions = processWebmentions(mentions);
	}
}

// Hint to linter that these identifiers are intentionally used in the template markup below.
// This keeps zero runtime impact while satisfying static analysis.
void [
	Layout,
	img,
	truncatedTitle,
	formatSiteDate,
	BlogPostingSchema,
	PodcastEpisodeSchema,
	ArticleContent,
	SeriesIntroContent,
	ArticleCard,
	articleEyebrowText,
	articleEyebrowHref,
];
---

<Layout
  title={truncatedTitle}
	showHeading={false}
  image={img}
	imageAlt={pageEntry?.data.imageAlt}
  description={pageEntry?.data.description}
  keywords={pageEntry?.data.keywords}
	noIndex={!isSeriesPage && pageEntry?.data.published === false}
  canonical={pageEntry?.data.canonical ?? undefined}
	translations={translations}
  noHeader>
	{!isSeriesPage && section === "blog" && article && (
		<BlogPostingSchema
			slot="head"
			headline={article.data.title}
			description={article.data.description}
			datePublished={article.data.date}
			dateModified={article.data.updated}
			image={img}
			url={Astro.url.href}
			canonical={article.data.canonical}
			translations={article.data.translations}
		/>
	)}

	{!isSeriesPage && section === "speaking" && article?.data.type === "podcast" && (
		<PodcastEpisodeSchema
			slot="head"
			name={article.data.title}
			description={article.data.description}
			datePublished={article.data.date}
			url={Astro.url.href}
			canonical={article.data.canonical}
			image={img}
			publisherName={article.data.publisherName}
			publisherUrl={article.data.publisherUrl}
		/>
	)}

	{isSeriesPage ? (
		<>
			{seriesIntroEntry?.data.eyebrow && <p class="eyebrow">{seriesIntroEntry.data.eyebrow}</p>}
			{SeriesIntroContent && <SeriesIntroContent components={{ img: Image }} />}

			<section class="series" aria-labelledby="series-articles-heading">
				<h2 id="series-articles-heading">Articles in this series</h2>
				{seriesArticles.map((seriesArticle: any) => (
					<ArticleCard
						article={seriesArticle}
						section="blog"
						imageLoading="lazy"
						headingOffset={1}
					/>
				))}
			</section>
		</>
	) : (
		article && (
			<article>
					{articleEyebrowText && (
						<p class="eyebrow">
							{articleEyebrowHref ? <a href={articleEyebrowHref}>{articleEyebrowText}</a> : articleEyebrowText}
						</p>
					)}
					{ArticleContent && <ArticleContent components={{ img: Image }} />}
					<footer>
						<p class="published">
							Published on <time datetime={article.data.date}>{formatSiteDate(article.data.date)}</time>
							{article.data.canonical && (
								<>
									{" "}via <a href={article.data.canonical} target="_blank" rel="noopener noreferrer">
										{new URL(article.data.canonical).hostname.replace(/^www\./, "").split(".")[0]}
									</a>
								</>
							)} by <a href="/about/" class="author">Michaël Vanderheyden</a>
						</p>
						{article.data.updated && (
							<p class="updated">
								Last updated on <time datetime={article.data.updated}>{formatSiteDate(article.data.updated)}</time>
							</p>
						)}
						<button type="button" class="share-button hidden">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 256 256" aria-hidden="true" focusable="false">
								<path d="M176,160a39.89,39.89,0,0,0-28.62,12.09l-46.1-29.63a39.8,39.8,0,0,0,0-28.92l46.1-29.63a40,40,0,1,0-8.66-13.45l-46.1,29.63a40,40,0,1,0,0,55.82l46.1,29.63A40,40,0,1,0,176,160Zm0-128a24,24,0,1,1-24,24A24,24,0,0,1,176,32ZM64,152a24,24,0,1,1,24-24A24,24,0,0,1,64,152Zm112,72a24,24,0,1,1,24-24A24,24,0,0,1,176,224Z"></path>
							</svg>
							<span>Share</span>
						</button>

						<Reactions webmentions={webmentions ?? undefined} syndicationLinks={article.data.syndication} />
					</footer>
				</article>
		)
	)}

	{!isSeriesPage && article && (
		<aside slot="aside">
			<h2>You might also like</h2>
			<RelatedArticles currentArticle={article} />
		</aside>
	)}

	<script>
		import "baseline-status";

		// Only show the share button if the Web Share API is supported
		if (navigator.share) {
			const shareButtons = document.querySelectorAll(".share-button");
			for (const shareButton of shareButtons) {
				shareButton.addEventListener("click", async () => {
					try {
						await navigator.share({
							title: document.title,
							url: window.location.href,
						});
					} catch {
						// User cancelled or error occurred
					}
				});
				shareButton.classList.remove("hidden");
			}
		}

		/**
		 * A11y: Add tabindex="0" to horizontally scrollable <pre> blocks
		 * https://www.w3.org/WAI/standards-guidelines/act/rules/0ssw9k/
		 */
		function updatePreTabIndex(pre: Element) {
			const element = pre as HTMLElement;
			if (element.scrollWidth > element.clientWidth) {
				if (!element.hasAttribute("tabindex")) {
					element.setAttribute("tabindex", "0");
				}
			} else {
				// Remove tabindex if no longer scrollable
				if (element.getAttribute("tabindex") === "0") {
					element.removeAttribute("tabindex");
				}
			}
		}

		// Observe each pre element for resize events
		if ("ResizeObserver" in window) {
			const resizeObserver = new ResizeObserver((entries) => {
				for (const entry of entries) {
					updatePreTabIndex(entry.target);
				}
			});

			document.querySelectorAll("pre").forEach((pre) => {
				updatePreTabIndex(pre);
				resizeObserver.observe(pre);
			});
		} else {
			// Fallback: just set initial tabindex without observation
			document.querySelectorAll("pre").forEach((pre) => {
				updatePreTabIndex(pre);
			});
		}
	</script>
</Layout>
