---



import { getCollection } from "astro:content";
import ArticleCard from "../../../components/ArticleCard.astro";
import Layout from "../../../layouts/Layout.astro";
import { getEntryIds, isSeriesContainerId } from "../../../utils/contentSeries";
import { isPreviewFutureContentEnabled, isVisibleContent } from "../../../utils/contentVisibility";
import { getTagDisplayName, sortTags } from "../../../utils/tags.js";

interface Props {
	tag: string;
}

export async function getStaticPaths() {
	const now = new Date();
	const previewFuture = isPreviewFutureContentEnabled();

	// Fetch all content entries first so series container detection is not affected by visibility.
	const allBlogEntries = await getCollection("blog");
	const blog = allBlogEntries.filter(({ data }: any) => isVisibleContent(data, { now, previewFuture }));
	const speaking = await getCollection("speaking", ({ data }: any) => isVisibleContent(data, { now, previewFuture }));
	const blogIds = getEntryIds(allBlogEntries);
	const blogPosts = blog.filter((entry: any) => !isSeriesContainerId(entry.id, blogIds));

	const allContent = [
		...blogPosts.map((entry: any) => ({ section: "blog" as const, entry })),
		...speaking.map((entry: any) => ({ section: "speaking" as const, entry })),
	];

	// Get all unique tags that have content
	const tagsWithContent = new Set<string>();
	allContent.forEach(({ entry }) => {
		if (entry.data.tags) {
			entry.data.tags.forEach((tag: string) => {
				tagsWithContent.add(tag);
			});
		}
	});

	// Generate paths for each tag
	return Array.from(tagsWithContent).map((tag) => ({
		params: { tag },
		props: { tag },
	}));
}

const { tag } = Astro.props;
const now = new Date();
const previewFuture = isPreviewFutureContentEnabled();

// Fetch all blog and speaking entries
const allBlogEntries = await getCollection("blog");
const blog = allBlogEntries.filter(({ data }: any) => isVisibleContent(data, { now, previewFuture }));
const speaking = await getCollection("speaking", ({ data }: any) => isVisibleContent(data, { now, previewFuture }));

const blogIds = getEntryIds(allBlogEntries);
const blogPosts = blog.filter((entry: any) => !isSeriesContainerId(entry.id, blogIds));

const allContent = [
	...blogPosts.map((entry: any) => ({ section: "blog" as const, entry })),
	...speaking.map((entry: any) => ({ section: "speaking" as const, entry })),
];

// Build tag navigation from all visible content.
const tagsWithContent = new Set<string>();
allContent.forEach(({ entry }) => {
	if (entry.data.tags) {
		entry.data.tags.forEach((entryTag: string) => {
			tagsWithContent.add(entryTag);
		});
	}
});

const allTags = sortTags(Array.from(tagsWithContent));

// Filter all content by the current tag.
const combined = allContent
	.filter(({ entry }) => entry.data.tags?.includes(tag))
	.sort((a, b) => new Date(b.entry.data.date).getTime() - new Date(a.entry.data.date).getTime());

const displayName = getTagDisplayName(tag);

// Ensure linter recognizes these as used in the template section below
void [combined, Layout, ArticleCard, allTags];
---

<Layout title={`${displayName} - blog`} heading={`Articles tagged with "${displayName}"`}>
	{allTags.length > 0 && (
		<nav class="tags" aria-label="Filter articles by tag">
			<ul>
				{allTags.map((tagOption) => (
					<li>
						<a href={`/blog/tags/${tagOption}`} class="tag" aria-current={tagOption === tag ? "page" : undefined}>
							{getTagDisplayName(tagOption)}
						</a>
					</li>
				))}
			</ul>
		</nav>
	)}

	{combined.length > 0 ? (
		combined.map(({ section, entry }) => {
			return (
				<ArticleCard
					article={entry}
					section={section}
					imageLoading="lazy"
					showType={true}
				/>
			);
		})
	) : (
		<p>No articles found with this tag.</p>
	)}
</Layout>
