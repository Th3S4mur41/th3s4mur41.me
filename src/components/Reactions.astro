---
// src/components/Reactions.astro
import type { ProcessedWebmentions, WebmentionAuthor } from "../utils/webmentions";

interface Props {
	/** Processed webmention data to display (optional, defaults to empty) */
	webmentions?: ProcessedWebmentions;
  /** Optional list of syndicated social post URLs */
  syndicationLinks?: string[];
}

const defaultWebmentions: ProcessedWebmentions = {
	likes: [],
	reposts: [],
	replies: [],
	mentions: [],
	stats: {
		likes: 0,
		reposts: 0,
		replies: 0,
		mentions: 0,
	},
};

const { webmentions = defaultWebmentions, syndicationLinks = [] } = Astro.props;

// Get the top 10 actors for likes and reposts
import { getTopActors } from "../utils/webmentions";

const likeActors = getTopActors(webmentions.likes, 10);
const repostActors = getTopActors(webmentions.reposts, 10);

// Check if we have any reactions to display
const hasReactions = webmentions.stats.likes > 0 || webmentions.stats.reposts > 0;

// Safe URL parsing helper - only allow http/https URLs
function getSafeHttpUrl(url: string | undefined): URL | null {
  if (!url) return null;
  try {
    const parsed = new URL(url);
    if (parsed.protocol !== "http:" && parsed.protocol !== "https:") return null;
    return parsed;
  } catch {
    return null;
  }
}

const validSyndicationLinks = syndicationLinks
  .map((url) => {
    try {
      const parsed = new URL(url);
      return { url, hostname: parsed.hostname.replace(/^www\./, "") };
    } catch {
      return null;
    }
  })
  .filter((entry): entry is { url: string; hostname: string } => Boolean(entry));

const hasSyndication = validSyndicationLinks.length > 0;

function getPlatformLabel(hostname: string) {
  if (hostname === "bsky.app") return "Bluesky";
  if (hostname === "linkedin.com") return "LinkedIn";
  return hostname;
}
---

{
  <section class="reactions" aria-labelledby="reactions-header">
    <header id="reactions-header">Reactions</header>
    <div id="likes">
       <svg aria-labelledby="likes-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentcolor" viewBox="0 0 256 256"><title id="likes-icon">Likes</title><path d="M178,40c-20.65,0-38.73,8.88-50,23.89C116.73,48.88,98.65,40,78,40a62.07,62.07,0,0,0-62,62c0,70,103.79,126.66,108.21,129a8,8,0,0,0,7.58,0C136.21,228.66,240,172,240,102A62.07,62.07,0,0,0,178,40ZM128,214.8C109.74,204.16,32,155.69,32,102A46.06,46.06,0,0,1,78,56c19.45,0,35.78,10.36,42.6,27a8,8,0,0,0,14.8,0c6.82-16.67,23.15-27,42.6-27a46.06,46.06,0,0,1,46,46C224,155.61,146.24,204.15,128,214.8Z"></path></svg>
       <span class="count">{webmentions.stats.likes}</span> 
        <div class="avatars" id="like-avatars">
         {likeActors.map((author) => {
           const safeUrl = getSafeHttpUrl(author.url);
           const hostname = safeUrl ? safeUrl.hostname.replace(/^www\./, "") : "";
           const titleText = author.name ? `${author.name}${hostname ? ` (${hostname})` : ''}` : "User";
           const img = (
             <img
               src={author.photo}
               alt={author.name || "User"}
               title={titleText}
               width="32"
               height="32"
               loading="lazy"
               decoding="async"
             />
           );
          
           return safeUrl ? (
             <a href={safeUrl.href} target="_blank" rel="noopener noreferrer external ugc nofollow">
               {img}
             </a>
           ) : (
             img
           );
         })}
       </div>
    </div>
    <div id="boosts">
       <svg aria-labelledby="boosts-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentcolor" viewBox="0 0 256 256"><title id="boosts-icon">Boosts</title><path d="M223.85,47.12a16,16,0,0,0-15-15c-12.58-.75-44.73.4-71.41,27.07L132.69,64H74.36A15.91,15.91,0,0,0,63,68.68L28.7,103a16,16,0,0,0,9.07,27.16l38.47,5.37,44.21,44.21,5.37,38.49a15.94,15.94,0,0,0,10.78,12.92,16.11,16.11,0,0,0,5.1.83A15.91,15.91,0,0,0,153,227.3L187.32,193A15.91,15.91,0,0,0,192,181.64V123.31l4.77-4.77C223.45,91.86,224.6,59.71,223.85,47.12ZM74.36,80h42.33L77.16,119.52,40,114.34Zm74.41-9.45a76.65,76.65,0,0,1,59.11-22.47,76.46,76.46,0,0,1-22.42,59.16L128,164.68,91.32,128ZM176,181.64,141.67,216l-5.19-37.17L176,139.31Zm-74.16,9.5C97.34,201,82.29,224,40,224a8,8,0,0,1-8-8c0-42.29,23-57.34,32.86-61.85a8,8,0,0,1,6.64,14.56c-6.43,2.93-20.62,12.36-23.12,38.91,26.55-2.5,36-16.69,38.91-23.12a8,8,0,1,1,14.56,6.64Z"></path></svg>
       <span class="count">{webmentions.stats.reposts}</span> 
        <div class="avatars" id="repost-avatars">
         {repostActors.map((author) => {
           const safeUrl = getSafeHttpUrl(author.url);
           const hostname = safeUrl ? safeUrl.hostname.replace(/^www\./, "") : "";
           const titleText = author.name ? `${author.name}${hostname ? ` (${hostname})` : ''}` : "User";
           const img = (
             <img
               src={author.photo}
               alt={author.name || "User"}
               title={titleText}
               width="32"
               height="32"
               loading="lazy"
               decoding="async"
             />
           );
          
           return safeUrl ? (
             <a href={safeUrl.href} target="_blank" rel="noopener noreferrer external ugc nofollow">
               {img}
             </a>
           ) : (
             img
           );
         })}
       </div>
    </div>
    {hasSyndication && (
      <p>
        Join the conversation on {validSyndicationLinks.map((link, index) => (
          <>
            {index > 0 ? (index === validSyndicationLinks.length - 1 ? " and " : ", ") : ""}
            <a href={link.url} target="_blank" rel="external noopener syndication">{getPlatformLabel(link.hostname)}</a>
          </>
        ))}
      </p>
    )}
  </section>
}
