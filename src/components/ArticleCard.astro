---

import type { ImageMetadata } from "astro";
import { formatSiteDate } from "../utils/config";
import Image from "./Image.astro";

interface ReadingStats {
	text?: string;
	words?: number;
	minutes?: number;
	time?: number;
}

interface Props {
	article: {
		id: string;
		body?: string;
		data: {
			title?: string;
			description?: string;
			date: string | Date;
			type?: string;
			image?: ImageMetadata | string;
			imageAlt?: string;
			readingTime?: ReadingStats;
		};
	};
	/** Section slug used to build default href and to scope generated IDs. */
	section: string;
	/** Optional override for the card link. Defaults to `/${section}/${article.id}/`. */
	href?: string;

	/**
	 * Heading offset from the default (h2).
	 * - `0` (default) -> `h2`
	 * - `1` -> `h3`
	 */
	headingOffset?: number;

	imageLoading?: "lazy" | "eager";

	showType?: boolean;
	type?: string;

	/** Emphasized treatment for prominent cards (e.g., larger hero or typography). */
	featured?: boolean;
	/** Editorially pinned card state, independent from layout emphasis. */
	pinned?: boolean;
}

const props = Astro.props as Props;

const {
	article,
	section,
	href,
	headingOffset = 0,
	imageLoading,
	showType = false,
	type,
	featured = false,
	pinned = false,
} = props;

const resolvedHref = href ?? `/${section}/${article.id}/`;
const sanitizedId = article.id.replace(/\//g, "-");
// Keep view-transition names stable and CSS-safe for nested content paths.
const transitionId = sanitizedId;

const dateValue = typeof article.data.date === "string" ? article.data.date : article.data.date.toISOString();
const dateObj = new Date(article.data.date);
const resolvedType = type ?? article.data.type;

type HeadingTagName = "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
// Cards default to h2 and can be shifted down by context (e.g. list inside a section).
const headingLevel = Math.min(6, Math.max(1, 2 + headingOffset));
const HeadingTag = `h${headingLevel}` as HeadingTagName;

const resolvedImage = article.data.image;

const resolvedImageAlt = article.data.imageAlt ?? "";

// Reading time is now computed during collection loading and available on entry.data
const readingStats = section === "blog" ? article.data.readingTime : undefined;

// TODO: consider extracting this formatting logic into a shared utility function (duplicated in ArticlePageHeader) and reusing it across the codebase for consistency)
// Only show reading metadata when both duration text and a valid word count exist.
const readingText = readingStats && typeof readingStats.text === "string" ? readingStats.text : null;
const candidateWordCount = readingStats?.words;
const wordCount = typeof candidateWordCount === "number" && Number.isFinite(candidateWordCount) && candidateWordCount > 0
	? candidateWordCount
	: null;
const formattedWords = typeof wordCount === "number" ? new Intl.NumberFormat("en-GB").format(wordCount) : null;
const readingMeta = readingText && formattedWords ? `${readingText} • ${formattedWords} words` : null;

function humanizeSlug(value: string): string {
	return value
		.split("/")
		.filter(Boolean)
		.pop()
		?.split("-")
		.map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
		.join(" ") ?? value;
}

function getPlainTextExcerpt(markdown: string, maxLength = 160): string {
	const text = markdown
		.replace(/^---[\s\S]*?---\s*/m, "")
		.replace(/^\s*(?:import|export)\b.*$/gm, " ")
		.replace(/```[\s\S]*?```/g, " ")
		.replace(/`([^`]+)`/g, "$1")
		.replace(/\[(.*?)\]\((.*?)\)/g, "$1")
		.replace(/[>#*_~=-]/g, " ")
		.replace(/\s+/g, " ")
		.trim();

	if (text.length <= maxLength) return text;
	return `${text.slice(0, maxLength).trimEnd()}...`;
}

const NOTE_CARD_SUMMARY_MAX_LENGTH = 300;
const trimmedTitle = article.data.title?.trim();
const trimmedDescription = article.data.description?.trim();
const resolvedCardTitle = trimmedTitle || humanizeSlug(article.id);
const resolvedSummary = trimmedDescription
	? trimmedDescription
	: article.body
		? getPlainTextExcerpt(article.body, section === "notes" ? NOTE_CARD_SUMMARY_MAX_LENGTH : 160)
		: null;

---

	<article class:list={["card", "h-entry", { featured, pinned }]}> 
		<HeadingTag class="p-name" style={`view-transition-name: article-title-${transitionId};`}><a class="u-url" href={resolvedHref}>
			{resolvedCardTitle}</a></HeadingTag>
		{showType && resolvedType && <span class="type">{resolvedType}</span>}
		{resolvedImage && (
			<Image
				src={resolvedImage}
				alt={resolvedImageAlt}
				class="u-featured"
				loading={imageLoading}
				decoding="auto"
				style={`view-transition-name: article-hero-image-${transitionId};`}
			/>
		)}
		{resolvedSummary && (
		<p class="p-summary">{resolvedSummary}</p>
		)}
		<time class="dt-published" datetime={dateValue}>
			{formatSiteDate(dateObj)}
		</time>
		{readingMeta && <div class="reading-meta">{readingMeta}</div>}
	</article>
