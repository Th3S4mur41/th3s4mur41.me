---



import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	src: ImageMetadata | string;
	alt: string;
	width?: number | string;
	height?: number | string;
	sourceContext?: string;
	widths?: {
		xSmall?: number;
		small?: number;
		medium?: number;
		large?: number;
	};
	sizes?: string;
	loading?: "lazy" | "eager";
	decoding?: "async" | "sync" | "auto";
	class?: string;
	fetchpriority?: "high" | "low" | "auto";
	style?: string;
	id?: string;
	title?: string;
}

const {
	src,
	alt,
	width,
	height,
	sourceContext,
	widths,
	sizes = "auto",
	loading = "lazy",
	decoding = "async",
	class: className,
	fetchpriority,
	style,
	id,
	title,
} = Astro.props;

function isImageMetadata(value: ImageMetadata | string): value is ImageMetadata {
	return typeof value === "object" && value !== null && "src" in value && "width" in value && "height" in value;
}

const imageMetadata = isImageMetadata(src) ? src : null;
const stringSrc = typeof src === "string" ? src : null;

// Get original image size directly from metadata to avoid extra pipeline run
const originalWidth = imageMetadata?.width;
const originalFormat = imageMetadata?.format || "png";
const isSvg = originalFormat.toLowerCase() === "svg";

// For SVG, skip transformations to preserve vector benefits
let avifSrcset = "";
let fallbackImage: any = null;
let shouldUseRawImage = !imageMetadata;
const rawImageWidth = width ?? imageMetadata?.width;
const rawImageHeight = height ?? imageMetadata?.height;
const imageContext = sourceContext ?? Astro.url?.pathname ?? "unknown-source";
const defaultWidths = { xSmall: 320, small: 480, medium: 820, large: 1440 };
const heroWidths = { xSmall: 480, small: 820, medium: 1280, large: 1920 };
const shouldUseHeroWidths = !widths && loading === "eager" && sizes === "auto";
const resolvedWidths = widths ?? (shouldUseHeroWidths ? heroWidths : defaultWidths);

if (!isSvg && imageMetadata && originalWidth) {
	// Normalize widths to ensure all breakpoints have values
	const {
		xSmall: xSmallWidth = 320,
		small: smallWidth = 480,
		medium: mediumWidth = 820,
		large: largeWidth = 1440,
	} = resolvedWidths;

	const isJpeg = originalFormat.toLowerCase() === "jpg" || originalFormat.toLowerCase() === "jpeg";
	const fallbackFormat = isJpeg ? "jpg" : "png";

	try {
		// Generate AVIF images for all sizes based on original size
		const avifXSmallWidth = Math.min(originalWidth, xSmallWidth);
		const avifSmallWidth = Math.min(originalWidth, smallWidth);
		const avifMediumWidth = Math.min(originalWidth, mediumWidth);
		const avifLargeWidth = Math.min(originalWidth, largeWidth);

		const avifXSmall = await getImage({ src: imageMetadata, width: avifXSmallWidth, format: "avif" });
		const avifSmall = await getImage({ src: imageMetadata, width: avifSmallWidth, format: "avif" });
		const avifMedium = await getImage({ src: imageMetadata, width: avifMediumWidth, format: "avif" });
		const avifLarge = await getImage({ src: imageMetadata, width: avifLargeWidth, format: "avif" });

		// Generate fallback image (use original format for JPEG, PNG otherwise)
		fallbackImage = await getImage({
			src: imageMetadata,
			width: originalWidth < mediumWidth ? originalWidth : mediumWidth,
			format: fallbackFormat,
			quality: 80,
		});

		// Create AVIF srcset string based on original size
		if (originalWidth <= xSmallWidth) {
			avifSrcset = `${avifXSmall.src} ${avifXSmallWidth}w`;
		} else if (originalWidth <= smallWidth) {
			avifSrcset = `${avifXSmall.src} ${avifXSmallWidth}w, ${avifSmall.src} ${avifSmallWidth}w`;
		} else if (originalWidth <= mediumWidth) {
			avifSrcset = `${avifXSmall.src} ${avifXSmallWidth}w, ${avifSmall.src} ${avifSmallWidth}w, ${avifMedium.src} ${avifMediumWidth}w`;
		} else if (originalWidth <= largeWidth) {
			avifSrcset = `${avifXSmall.src} ${avifXSmallWidth}w, ${avifSmall.src} ${avifSmallWidth}w, ${avifMedium.src} ${avifMediumWidth}w, ${avifLarge.src} ${avifLargeWidth}w`;
		} else {
			avifSrcset = `${avifXSmall.src} ${avifXSmallWidth}w, ${avifSmall.src} ${avifSmallWidth}w, ${avifMedium.src} ${avifMediumWidth}w, ${avifLarge.src} ${avifLargeWidth}w`;
		}
	} catch (error) {
		const imageRef = imageMetadata.src ?? "unknown-image";
		throw new Error(
			`Image optimization failed for metadata source "${imageRef}" in "${imageContext}". Please fix the image pipeline/config instead of using raw fallback.`,
			{ cause: error },
		);
	}
}

const rawSrc = imageMetadata?.src ?? stringSrc ?? "";

if (stringSrc && !rawImageWidth && !rawImageHeight && import.meta.env.DEV) {
	console.warn(
		`[Image] String source rendered without width/height for "${stringSrc}" in "${imageContext}". Consider passing width and height to prevent layout shift.`,
	);
}
---

{isSvg || shouldUseRawImage ? (
	<img
		src={rawSrc}
		alt={alt}
		width={rawImageWidth}
		height={rawImageHeight}
		loading={loading}
		decoding={decoding}
		class={className}
		fetchpriority={fetchpriority}
		style={style}
		id={id}
		title={title}
	/>
) : (
	<picture>
		<source type="image/avif" srcset={avifSrcset} sizes={sizes} />
		<img
			src={fallbackImage.src}
			alt={alt}
			width={fallbackImage.attributes.width}
			height={fallbackImage.attributes.height}
			loading={loading}
			decoding={decoding}
			class={className}
			fetchpriority={fetchpriority}
			style={style}
			id={id}
			title={title}
		/>
	</picture>
)}
